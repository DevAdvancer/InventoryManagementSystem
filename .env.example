# =====================================================================
# Root .env — consumed by docker compose.
# These vars are interpolated into docker-compose.yml AND injected into
# the backend container as environment variables.
# =====================================================================

# --- Postgres ---------------------------------------------------------
# Direct Postgres URL. For Railway, copy the DATABASE_URL from the
# Railway Postgres service's Variables tab.
#
# If you point at a pgbouncer-style transaction pooler, set
# USE_PGBOUNCER=true and append ?pgbouncer=true to the URL. For a
# direct Postgres — Railway, Render, local — leave USE_PGBOUNCER=false.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Set to true ONLY when DATABASE_URL points at a pgbouncer front-end.
USE_PGBOUNCER=false

# --- CORS --------------------------------------------------------------
# Comma-separated list of allowed origins, or "*" for any.
# Put your deployed frontend URL here in production, e.g.:
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=*

# --- Backend (container) -----------------------------------------------
BACKEND_PORT=8000

# --- Frontend ----------------------------------------------------------
FRONTEND_PORT=8080

# Bake the deployed backend URL into the React build so the UI
# talks to it on first load. Leave BLANK in local dev — the frontend
# nginx will proxy /api -> backend automatically.
# Example for production:
#   REACT_APP_API_URL=https://your-api.example.com
REACT_APP_API_URL=
