# =====================================================================
# Backend env (used by FastAPI in Docker or local uvicorn)
# =====================================================================

# --- Database ----------------------------------------------------------
# Direct Postgres URL — paste the DATABASE_URL from your Railway
# Postgres service (or any managed / local Postgres). The backend
# creates the schema and seeds baseline data automatically on startup,
# so a brand-new database is usable with no manual SQL.
#
# Examples:
#   Railway:   postgresql://postgres:<PWD>@<host>.proxy.rlwy.net:<PORT>/railway
#   Local:     postgresql://postgres:postgres@localhost:5432/inventory_db
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Set to true ONLY when DATABASE_URL points at a pgbouncer-style
# transaction pooler. Leave false for direct Postgres (Railway, local).
USE_PGBOUNCER=false

# --- Application -------------------------------------------------------
APP_NAME=Inventory & Order Management API
APP_VERSION=1.0.0
DEBUG=false

# Comma-separated list of allowed origins, or "*" for any.
# Example for production:
#   CORS_ORIGINS=https://your-app.vercel.app,https://your-app-staging.vercel.app
CORS_ORIGINS=*
